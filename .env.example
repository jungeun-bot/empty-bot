# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Google Service Account
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json
# OR inline JSON (takes priority if set):
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com"}

# Google Workspace Admin (for Directory API - Domain-Wide Delegation)
GOOGLE_ADMIN_EMAIL=admin@your-company.com

# Timezone
GOOGLE_CALENDAR_TIMEZONE=Asia/Seoul

# Rooms Configuration (JSON array - optional, defaults provided in code)
# ROOMS_CONFIG=[{"id":"room-a@resource.calendar.google.com","name":"회의실 A","capacity":4,"floor":"2F"},{"id":"room-b@resource.calendar.google.com","name":"회의실 B","capacity":8,"floor":"2F","amenities":["프로젝터"]},{"id":"room-c@resource.calendar.google.com","name":"대회의실","capacity":20,"floor":"3F","amenities":["프로젝터","화상회의"]}]

# Admin (optional) - 신고/건의 수신자 Slack User ID
ADMIN_SLACK_USER_ID=U012345ADMIN
